import Select from "@components/Select/Select.astro";
import { getLocaleFromUrl } from "@js/localeUtils";
import { useTranslations, getLocalizedPathname } from "@js/translationUtils";
import { locales } from "@config/siteSettings";

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);

const options = await Promise.all(
  locales.map(async (l) => ({
    value: await getLocalizedPathname(l, Astro.url),
    selected: l === locale,
    label: t(`languageSelect.${l}`),
  }))
);
---

{
	(
		<starlight-lang-select>
			<Select
				icon="mdi--language"
				label={locale}
				value={locale}
				options={options}
				width="6em"
			/>
		</starlight-lang-select>
	)
}

<script>
	import { setLocalePreference } from "@js/localePreference";

	class StarlightLanguageSelect extends HTMLElement {
		constructor() {
			super();
			const select = this.querySelector("select");
			if (select) {
				select.addEventListener("change", (e) => {
					if (e.currentTarget instanceof HTMLSelectElement) {
						setLocalePreference(e.currentTarget.value);
					window.location.pathname = e.currentTarget.value;
					}
				});
			}
		}
	}
	customElements.define("starlight-lang-select", StarlightLanguageSelect);
</script>
