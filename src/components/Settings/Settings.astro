---
import ThemeSelect from "@components/DarkMode/ThemeSelect.astro";
import TwoLocalesSelect from "@components/LanguageSwitch/TwoLocalesSelect.astro";

---

<div class="options-wrapper">
	<TwoLocalesSelect />
	<ThemeSelect />
</div>

<style>
	/* Mobile */
	@media only screen and (min-width: 0) {
		.options-wrapper {
			display: flex;
			flex-direction: column;
			align-items: center;
			margin-left: auto;
			border-top: 1px solid hsl(224, 6%, 77%);
			padding-block: 1em;
		}

		body.dark-mode {
			.options-wrapper {
				border-top: 1px solid hsl(224, 10%, 23%);
			}
		}
	}

	@media only screen and (min-width: 64rem) {
		.options-wrapper {
			display: flex;
			flex-direction: row;
			padding: 0;
			border-top: none;
			gap: 1.5em;
		}

		body.dark-mode {
			.options-wrapper {
				border-top: none;
			}
		}
	}
</style>
