---
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/Hero/Hero.astro";
import Features from "@components/Features/Features.astro";
import Platforms from "@components/Platforms/Platforms.astro";
import Demo from "@components/Demo/Demo.astro";
import Testimonials from "@components/Testimonials/Testimonials.astro";
import CTA from "@components/CTA/CTA.astro";
import { getLocaleFromUrl } from "@js/localeUtils";
import { useTranslations } from "@js/translationUtils";
import BrowserLanguageRedirect from "@components/LanguageSwitch/BrowserLanguageRedirect.astro";
import landingImage from "@assets/images/hero.jpg";

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
---

<BrowserLanguageRedirect />

<BaseLayout title={t("home:layout.title")} description={t("home:layout.description")}>
	<Hero image={landingImage} />
	<Features />
	<Platforms />
	<Demo />
	<Testimonials />
	<CTA />
</BaseLayout>
